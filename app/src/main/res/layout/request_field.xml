<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/attachmentsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:padding="4dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/addAttachment"
            android:layout_width="30dp"
            android:layout_height="48dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@drawable/ic_bg_b"
            app:tint="@color/stroke" />

        <EditText
            android:id="@+id/contentInput"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="5"
            android:textCursorDrawable="@drawable/white_cursor"
            android:hint="content"
            android:textColorHint="@color/hint"
            android:textColor="@color/text"
            android:inputType="textMultiLine|textCapSentences"
            android:background="@null" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:padding="6dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/ic_bg_g" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/settingsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:background="@color/bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="10dp"
                android:paddingRight="30dp"
                android:text="INCLUDE REASONING"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/reasoningYes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="YES"
                    android:textColor="@color/text"
                    android:textSize="12sp"
                    android:background="@drawable/ic_bg_b" />

                <TextView
                    android:id="@+id/reasoningAuto"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="AUTO"
                    android:textColor="@color/text"
                    android:textSize="12sp"
                    android:background="@drawable/ic_bg_g" />

                <TextView
                    android:id="@+id/reasoningNo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="NO"
                    android:textColor="@color/text"
                    android:textSize="12sp"
                    android:background="@drawable/ic_bg_b" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:text="MAX TOKENS"
            android:textColor="@color/text"
            android:textSize="13sp" />
        <EditText
            android:textCursorDrawable="@drawable/white_cursor"
            android:id="@+id/maxTokens"
            android:padding="10dp"
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/hint"
            android:textColor="@color/text"
            android:hint="input..."
            android:inputType="numberDecimal"
            android:background="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:text="TEMPERATURE"
            android:textColor="@color/text"
            android:textSize="13sp" />
        <EditText
            android:textCursorDrawable="@drawable/white_cursor"
            android:id="@+id/temperature"
            android:padding="10dp"
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/hint"
            android:textColor="@color/text"
            android:hint="input..."
            android:inputType="numberDecimal"
            android:background="@null" />
    </LinearLayout>
</merge>
