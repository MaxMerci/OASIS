<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/attachmentsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:padding="4dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/addAttachment"
            android:layout_width="30dp"
            android:layout_height="48dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@drawable/ic_bg_b"
            app:tint="@color/stroke" />

        <EditText
            android:id="@+id/contentInput"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="5"
            android:textCursorDrawable="@drawable/white_cursor"
            android:hint="content"
            android:textColorHint="@color/hint"
            android:textColor="@color/text"
            android:inputType="textMultiLine|textCapSentences"
            android:background="@null" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:padding="6dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/ic_bg_g" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/settingsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:background="@color/bg">

        <CheckBox
            android:id="@+id/includeReasoning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INCLUDE REASONING"
            android:textColor="@color/text"
            android:buttonTint="@color/text"
            android:background="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:text="TEMPERATURE"
            android:textColor="@color/text"
            android:textSize="13sp" />
        <EditText
            android:textCursorDrawable="@drawable/white_cursor"
            android:id="@+id/temperature"
            android:padding="10dp"
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/hint"
            android:textColor="@color/text"
            android:hint="input..."
            android:inputType="number"
            android:background="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:text="TOP P"
            android:textColor="@color/text"
            android:textSize="13sp" />
        <EditText
            android:textCursorDrawable="@drawable/white_cursor"
            android:id="@+id/topP"
            android:padding="10dp"
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/hint"
            android:textColor="@color/text"
            android:hint="input..."
            android:inputType="number"
            android:background="@null" />
    </LinearLayout>
</merge>