<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="5dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/hint"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/name"
            android:text="NAME"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/hint"
            android:textSize="12sp"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/reasoning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0"
        android:visibility="gone"
        android:layout_margin="8dp">
        <TextView
            android:text="REASONING CURRENT"
            android:id="@+id/reasoningCurrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:visibility="gone"
            android:textColor="@color/hint"/>
        <TextView
            android:text="REASONING NEXT"
            android:id="@+id/reasoningNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:visibility="gone"
            android:textColor="@color/hint"/>
    </FrameLayout>

    <TextView
        android:text="TOOL USE"
        android:id="@+id/toolsUse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:layout_marginLeft="15dp"
        android:visibility="gone"
        android:textColor="@color/hint"/>

    <TextView
        android:text="CONTENT"
        android:id="@+id/content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:paddingLeft="12dp"
        android:paddingTop="3dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:alpha="0"
        android:visibility="gone"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:textIsSelectable="true"/>
</LinearLayout>